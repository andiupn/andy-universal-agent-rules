{
  "_comment": "Example MCP server configuration for Cursor. Copy to your local Cursor settings and replace <PATH_TO_MCP> with the absolute path to your MCP servers folder. Never commit real credentials — load secrets from environment variables.",
  "mcpServers": {
    "blogger": {
      "command": "node",
      "args": [
        "<PATH_TO_MCP>/blogger-mcp-server/index.js"
      ]
    },
    "playwright": {
      "command": "node",
      "args": [
        "<PATH_TO_MCP>/playwright-mcp-server/index.js"
      ],
      "note": "Requires: npx playwright install"
    },
    "context7": {
      "command": "node",
      "args": [
        "<PATH_TO_MCP>/context7-mcp-server/index.js"
      ]
    },
    "chrome_devtools": {
      "command": "node",
      "args": [
        "<PATH_TO_MCP>/chrome-devtools-mcp-server/index.js"
      ],
      "note": "Requires: Chrome/Chromium installation"
    },
    "postgres": {
      "command": "node",
      "args": [
        "<PATH_TO_MCP>/postgres-mcp-server/index.js"
      ],
      "env": {
        "POSTGRES_URL": "${POSTGRES_URL}"
      },
      "note": "Set POSTGRES_URL in your shell environment, do not hardcode credentials."
    },
    "langchain": {
      "command": "node",
      "args": [
        "<PATH_TO_MCP>/langchain-mcp-server/index.js"
      ],
      "note": "May require LangChain API keys via environment variables"
    },
    "oracle": {
      "command": "node",
      "args": [
        "<PATH_TO_MCP>/oracle-mcp-server/index.js"
      ],
      "env": {
        "ORACLE_HOST": "${ORACLE_HOST}",
        "ORACLE_PORT": "${ORACLE_PORT}",
        "ORACLE_SERVICE_NAME": "${ORACLE_SERVICE_NAME}",
        "ORACLE_USER": "${ORACLE_USER}",
        "ORACLE_PASSWORD": "${ORACLE_PASSWORD}"
      },
      "note": "Set Oracle connection details via environment variables."
    },
    "dbeaver": {
      "command": "<PATH_TO_MCP>/dbeaver-mcp-server/.venv/Scripts/python.exe",
      "args": [
        "<PATH_TO_MCP>/dbeaver-mcp-server/server.py"
      ],
      "note": "Multi-DB proxy (SQLite, MySQL, Oracle, PostgreSQL)"
    }
  }
}
